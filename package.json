{
  "name": "capacitor-share-extension",
  "version": "7.0.0",
  "description": "A Capacitor Plugin that provides native capabilities to retrieve media files sent via iOS Share Extension and Android Send Intent events",
  "main": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "scripts": {
    "build": "npm run clean && tsc && rollup -c rollup.config.mjs",
    "clean": "rm -rf ./dist",
    "watch": "tsc --watch",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "prettier": "prettier \"**/*.{css,html,ts,js,java}\" --plugin=prettier-plugin-java"
  },
  "author": "Calvin Ho, Jonathan Date-Chong",
  "license": "MIT",
  "dependencies": {
    "@capacitor/cli": "^7.0.0",
    "@capacitor/core": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@ionic/prettier-config": "^4.0.0",
    "@ionic/swiftlint-config": "^2.0.0",
    "@rollup/plugin-node-resolve": "^8.1.0",
    "@types/node": "^24.5.2",
    "prettier": "^3.4.2",
    "prettier-plugin-java": "^2.6.6",
    "rimraf": "^6.0.1",
    "rollup": "^4.30.1",
    "swiftlint": "^2.0.0",
    "typescript": "^5.9.2"
  },
  "files": [
    "dist/",
    "ios/",
    "android/",
    "CapacitorShareExtension.podspec"
  ],
  "keywords": [
    "capacitor",
    "plugin",
    "native"
  ],
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/calvinckho/capacitor-share-extension"
  },
  "bugs": {
    "url": "https://github.com/calvinckho/capacitor-share-extension/issues"
  }
}
